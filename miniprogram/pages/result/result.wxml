<view class="container">
  <view class="result-card">
    <view class="page-title">{{ui.title}}</view>
    <view wx:if="{{title}}" class="exam-title">{{title}}</view>

    <view class="score-row">
      <view class="score-value">{{score}}</view>
      <view class="score-meta">
        <view class="score-label">{{ui.scoreLabel}}</view>
        <view class="accuracy-line">{{ui.accuracyLabel}} {{accuracy}}%</view>
      </view>
    </view>

    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{total}}</view>
        <view class="stat-label">{{ui.totalLabel}}</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{answered}}</view>
        <view class="stat-label">{{ui.answeredLabel}}</view>
      </view>
      <view class="stat-item success">
        <view class="stat-value">{{correct}}</view>
        <view class="stat-label">{{ui.correctLabel}}</view>
      </view>
      <view class="stat-item danger">
        <view class="stat-value">{{wrong}}</view>
        <view class="stat-label">{{ui.wrongLabel}}</view>
      </view>
      <view class="stat-item warning">
        <view class="stat-value">{{remaining}}</view>
        <view class="stat-label">{{ui.remainingLabel}}</view>
      </view>
    </view>
  </view>

  <view class="comment-card">
    <view class="comment-icon">{{commentEmoji}}</view>
    <view class="comment-text">{{commentText}}</view>
  </view>

  <view class="action-buttons">
    <button class="btn-secondary" bindtap="onBackHome">{{ui.backHome}}</button>
    <button class="btn-primary" bindtap="onRetry">{{retryText}}</button>
  </view>
</view>

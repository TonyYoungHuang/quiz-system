.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4B8FE9 0%, #DDEBFF 280rpx, #F3F7FD 640rpx, #F4F7FC 100%);
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.result-card,
.comment-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.result-card {
  padding: 34rpx 28rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
}

.exam-title {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 600;
}

.score-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.score-value {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 68rpx;
  font-weight: 800;
  flex-shrink: 0;
  box-shadow: 0 16rpx 28rpx rgba(53, 122, 189, 0.18);
}

.score-meta {
  flex: 1;
}

.score-label {
  font-size: 30rpx;
  color: #111827;
  font-weight: 800;
}

.accuracy-line {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 600;
}

.stats-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 22rpx;
}

.stat-item.success {
  background: rgba(34, 197, 94, 0.10);
}

.stat-item.danger {
  background: rgba(239, 68, 68, 0.10);
}

.stat-item.warning {
  background: rgba(245, 158, 11, 0.12);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

.comment-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  text-align: center;
}

.comment-icon {
  font-size: 64rpx;
}

.comment-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #374151;
  font-weight: 600;
}

.action-buttons {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.action-buttons button {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.action-buttons button::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #357abd;
  border: 2rpx solid #357abd;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(53, 122, 189, 0.18);
}

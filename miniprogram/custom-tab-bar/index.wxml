<view class="tabbar-shell">
  <view class="tabbar-panel">
    <view
      wx:for="{{tabs}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'selected' : ''}}"
      bindtap="onSwitchTab"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
    >
      <view class="tab-pill">
        <text class="tab-label">{{item.text}}</text>
      </view>
    </view>
  </view>
</view>

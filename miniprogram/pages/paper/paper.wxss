/* pages/paper/paper.wxss */
.container {
  min-height: 100vh;
  background: #F6F7FB;
}

.exam-tabs {
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.exam-tab-list {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.exam-tab {
  padding: 12rpx 28rpx;
  background: #F2F4F7;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4A90E2;
  font-weight: 600;
  white-space: nowrap;
}

.exam-tab.active {
  background: #4A90E2;
  color: #fff;
}

.paper-list {
  padding: 20rpx 24rpx 40rpx;
}

.paper-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.paper-info {
  display: flex;
  flex-direction: column;
}

.paper-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2B2B2B;
  margin-bottom: 6rpx;
}

.paper-meta {
  font-size: 24rpx;
  color: #8B8B8B;
}

.paper-action {
  background: #4A90E2;
  color: #fff;
  border-radius: 28rpx;
  padding: 6rpx 20rpx;
  font-size: 24rpx;
}

.empty-state {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #999;
}

.empty-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
}

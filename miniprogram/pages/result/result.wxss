/* pages/result/result.wxss */

/* зјҒж’ҙзҒүйҚ—пј„еў– */
.result-card {
  background: #fff;
  margin: 40rpx 24rpx;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* йҚ’е—ҳжҡҹйҚҰе—ҷе№Ҷ */
.score-circle {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: conic-gradient(#4A90E2 0%, #4A90E2 {{accuracy * 3.6}}deg, #F0F0F0 {{accuracy * 3.6}}deg, #F0F0F0 360deg);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-circle::before {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border-radius: 50%;
}

.score-inner {
  position: relative;
  z-index: 1;
}

.score-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #4A90E2;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* зјҒзҶ»о…ёж·Үв„ғдј… */
.stats-info {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #F0F0F0;
}

/* е§қпҪҮвҖҳйҗң?*/
.accuracy-info {
  font-size: 28rpx;
}

.accuracy-label {
  color: #999;
  margin-right: 12rpx;
}

.accuracy-value {
  font-size: 36rpx;
  font-weight: 500;
}

/* з’ҮеӢӘзҺҜйҚ—пј„еў– */
.comment-card {
  background: #fff;
  margin: 0 24rpx 32rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.comment-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* йҺҝе¶„з¶”йҺёеӨҗжҢі */
.action-buttons {
  display: flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.action-buttons button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(74, 144, 226, 0.3);
}

/* pages/topic/topic.wxss */
.container {
  min-height: 100vh;
  background: #F6F7FB;
}

.exam-tabs {
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.exam-tab-list {
  display: inline-flex;
  padding: 18rpx 24rpx;
  gap: 18rpx;
}

.exam-tab {
  padding: 14rpx 34rpx;
  background: #F2F4F7;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #4A90E2;
  font-weight: 600;
  white-space: nowrap;
}

.exam-tab.active {
  background: #4A90E2;
  color: #fff;
}

.topic-list {
  padding: 20rpx 24rpx 40rpx;
}

.topic-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 24rpx 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(37, 99, 235, 0.08);
}

.topic-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.topic-header-main {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.topic-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #273142;
  line-height: 1.35;
  word-break: break-all;
}

.topic-meta {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.topic-meta-icon {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7EB6FF 0%, #4A90E2 100%);
  box-shadow: 0 0 0 6rpx rgba(74, 144, 226, 0.12);
}

.topic-count {
  font-size: 25rpx;
  color: #7E8A9F;
  font-weight: 600;
}

.topic-start {
  background: #4A90E2;
  color: #fff;
  border-radius: 30rpx;
  width: 176rpx;
  min-width: 176rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0;
  margin: 0 0 0 auto;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(74, 144, 226, 0.2);
}

.topic-start::after {
  border: none;
}

.topic-children {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.topic-child {
  background: #F2F6FF;
  color: #3B82F6;
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.topic-child-count {
  color: #7C8DB5;
  font-size: 20rpx;
}

.empty-state {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #999;
}

.empty-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
}

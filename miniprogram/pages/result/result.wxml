<!--pages/result/result.wxml-->
<view class="container">
  <view class="result-card">
    <view class="score-circle">
      <view class="score-inner">
        <view class="score-value">{{score}}</view>
        <view class="score-label">得分</view>
      </view>
    </view>

    <view class="stats-info">
      <view class="stat-item">
        <view class="stat-value text-primary">{{total}}</view>
        <view class="stat-label">总题数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value text-success">{{correct}}</view>
        <view class="stat-label">正确数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value text-danger">{{wrong}}</view>
        <view class="stat-label">错误数</view>
      </view>
    </view>

    <view class="accuracy-info">
      <text class="accuracy-label">正确率</text>
      <text class="accuracy-value text-primary">{{accuracy}}%</text>
    </view>
  </view>

  <view class="comment-card">
    <view class="comment-icon">{{commentEmoji}}</view>
    <view class="comment-text">{{commentText}}</view>
  </view>

  <view class="action-buttons">
    <button class="btn-secondary" bindtap="onBackHome">返回首页</button>
    <button class="btn-primary" bindtap="onRetry">再做一次</button>
  </view>
</view>

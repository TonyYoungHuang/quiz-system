/* pages/activate/activate.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 190rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #4B8FE9 0%, #DDEBFF 330rpx, #F3F7FD 740rpx, #F4F7FC 100%);
}

.hero-panel {
  background: linear-gradient(180deg, #4B8FE9 0%, #4A8DE8 100%);
  padding-bottom: 20rpx;
}

.page-header {
  background: transparent;
}

.page-header-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.page-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.hero-card {
  margin: 14rpx 24rpx 0;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  box-shadow: 0 16rpx 32rpx rgba(36, 107, 219, 0.18);
}

.hero-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.hero-current {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.14);
}

.hero-current-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
  line-height: 1;
}

.hero-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.hero-stat {
  flex: 1;
  min-height: 112rpx;
  border-radius: 22rpx;
  padding: 18rpx 18rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.16);
}

.hero-stat-value {
  display: block;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.hero-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.content-shell {
  padding: 18rpx 24rpx 24rpx;
}

.activate-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  border-radius: 28rpx;
  padding: 22rpx 24rpx 24rpx;
  box-shadow: 0 14rpx 32rpx rgba(83, 122, 196, 0.10);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
}

.card-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #8A95A8;
  background: rgba(245, 248, 254, 0.96);
  border: 2rpx solid rgba(223, 232, 249, 0.92);
}

.code-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 102rpx;
  padding: 0 22rpx 0 138rpx;
  margin-bottom: 18rpx;
  background: #F4F8FF;
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  border-radius: 26rpx;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
}

.code-icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.20);
}

.code-input {
  flex: 1;
  height: 102rpx;
  font-size: 28rpx;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.code-placeholder {
  color: #A0A8B8;
}

.code-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(160, 168, 184, 0.18);
  color: #7C8CA5;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.code-tips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tips-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #246BDB;
}

.tips-text {
  font-size: 22rpx;
  color: #8A95A8;
  font-weight: 600;
}

.activate-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.activate-btn::after {
  border: none;
}

.activate-btn.disabled {
  background: linear-gradient(180deg, #EEF2F8 0%, #E5EBF5 100%);
  color: #B2BBC9;
  box-shadow: none;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 2rpx 14rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1F2937;
}

.section-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #8A95A8;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  font-weight: 700;
}

.empty-activated {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 72rpx 0;
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.08);
}

.empty-icon {
  font-size: 68rpx;
  margin-bottom: 14rpx;
  opacity: 0.45;
}

.empty-text {
  font-size: 24rpx;
  color: #8A95A8;
  font-weight: 600;
}

.exam-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activated-item {
  display: flex;
  align-items: center;
  padding: 22rpx 22rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.item-icon {
  width: 82rpx;
  height: 82rpx;
  margin-right: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.18);
}

.item-icon-text {
  font-size: 42rpx;
  line-height: 1;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.item-name {
  min-width: 0;
  flex: 1;
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-pill {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #246BDB;
  background: rgba(226, 236, 253, 1);
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.item-category {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #246BDB;
  background: rgba(228, 236, 254, 1);
}

.item-count {
  font-size: 24rpx;
  color: #6F7D95;
  font-weight: 700;
}

.item-action {
  margin-left: 14rpx;
  min-width: 112rpx;
  height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #246BDB;
  background: rgba(240, 244, 253, 1);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

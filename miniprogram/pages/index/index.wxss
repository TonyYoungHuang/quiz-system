/* pages/index/index.wxss */
.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
  color: #9AA4B2;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.category-scroll {
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 18rpx 24rpx 22rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #F2F4F7;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 600;
}

.category-item.active {
  background: #4A90E2;
  color: #fff;
}

.exam-list {
  padding: 20rpx 24rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.exam-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #6B73E5 0%, #7D4CC7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.exam-icon-img {
  width: 64rpx;
  height: 64rpx;
}

.exam-info {
  flex: 1;
  min-width: 0;
}

.exam-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2B2B2B;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exam-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.exam-category {
  color: #4A90E2;
  font-size: 26rpx;
  font-weight: 600;
}

.exam-count {
  font-size: 26rpx;
  color: #9AA4B2;
}

.exam-status {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.status-badge.activated {
  background: rgba(82, 196, 26, 0.12);
  color: #52C41A;
}

.status-badge.locked {
  background: rgba(255, 77, 79, 0.12);
  color: #FF4D4F;
}

.status-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

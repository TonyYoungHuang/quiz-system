/* pages/exam/exam.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #4b8fe9 0%, #ddebff 320rpx, #f4f7fc 620rpx, #f7faff 100%);
}

.exam-hero {
  flex-shrink: 0;
  background: linear-gradient(180deg, #4b8fe9 0%, #4389eb 100%);
  box-shadow: 0 12rpx 28rpx rgba(54, 110, 194, 0.14);
}

.exam-hero-inner {
  padding: 0 24rpx 30rpx;
}

.hero-spacer {
  width: 100%;
}

.hero-toolbar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 4rpx;
}

.toolbar-side {
  flex-shrink: 0;
  width: 126rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.12);
}

.toolbar-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.toolbar-title {
  width: 100%;
  min-height: 72rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.14);
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.12);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.toolbar-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.toolbar-progress {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.toolbar-sub {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
}

.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.16);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffffff 0%, rgba(255, 255, 255, 0.72) 100%);
  border-radius: 999rpx;
}

.question-swiper {
  flex: 1;
  min-height: 0;
}

.question-scroll {
  height: 100%;
}

.question-card {
  min-height: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx 48rpx;
}

.question-type {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3f8cff 0%, #246bdb 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 20rpx rgba(36, 107, 219, 0.16);
}

.question-content {
  margin-top: 28rpx;
  margin-bottom: 24rpx;
}

.child-content {
  margin-top: 0;
}

.question-index {
  display: block;
  margin-bottom: 18rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #4a8de8;
}

.question-image {
  width: 100%;
  border-radius: 22rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.12);
}

.question-tools {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 18rpx;
}

.tool-favorite {
  min-width: 150rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(83, 122, 196, 0.08);
  font-size: 26rpx;
  font-weight: 700;
  color: #246bdb;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.tool-favorite.active {
  background: linear-gradient(180deg, #fff7df 0%, #ffefc0 100%);
  border-color: rgba(244, 198, 84, 0.82);
  color: #d48806;
}

.options-list {
  margin-bottom: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 22rpx 22rpx 22rpx 20rpx;
  margin-bottom: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fdfefe 100%);
  border: 2rpx solid rgba(216, 228, 247, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.option-item.selected {
  background: linear-gradient(180deg, #f5f9ff 0%, #eaf2ff 100%);
  border-color: #4a8de8;
  box-shadow: 0 14rpx 28rpx rgba(74, 141, 232, 0.16);
}

.option-item.correct {
  background: linear-gradient(180deg, #effaf0 0%, #e3f7e7 100%);
  border-color: rgba(82, 196, 26, 0.82);
}

.option-item.wrong {
  background: linear-gradient(180deg, #fff3f3 0%, #ffe8e8 100%);
  border-color: rgba(255, 77, 79, 0.78);
}

.option-key {
  width: 72rpx;
  height: 72rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6faff 100%);
  border: 2rpx solid rgba(208, 222, 245, 0.92);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.86);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f76de;
}

.option-item.selected .option-key {
  background: linear-gradient(135deg, #3f8cff 0%, #246bdb 100%);
  border-color: #3f8cff;
  color: #ffffff;
}

.option-item.correct .option-key {
  background: linear-gradient(135deg, #65d32e 0%, #41b513 100%);
  border-color: #52c41a;
  color: #ffffff;
}

.option-item.wrong .option-key {
  background: linear-gradient(135deg, #ff8585 0%, #ff5c5c 100%);
  border-color: #ff4d4f;
  color: #ffffff;
}

.option-value {
  flex: 1;
  min-width: 0;
}

.answer-analysis {
  margin-top: 12rpx;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(236, 244, 255, 0.82);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
}

.answer-analysis.success {
  background: rgba(239, 250, 240, 0.88);
  border-color: rgba(187, 232, 184, 0.96);
}

.answer-analysis.warning {
  background: rgba(255, 247, 229, 0.94);
  border-color: rgba(243, 213, 141, 0.92);
}

.analysis-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #246bdb;
}

.warning-text {
  color: #d48806;
}

.analysis-content {
  font-size: 26rpx;
  color: #5f6b7a;
  line-height: 1.7;
}

.correct-answer {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #5f6b7a;
}

.answer-text {
  color: #246bdb;
  font-weight: 700;
}

.footer-buttons {
  padding-top: 16rpx;
}

.result-buttons {
  width: 100%;
}

.btn-submit,
.btn-next,
.btn-finish {
  width: 100%;
  height: 92rpx;
  border: none;
  border-radius: 46rpx;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-submit::after,
.btn-next::after,
.btn-finish::after {
  border: none;
}

.btn-submit {
  background: linear-gradient(135deg, #3f8cff 0%, #246bdb 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(36, 107, 219, 0.16);
}

.btn-submit[disabled] {
  background: linear-gradient(180deg, #eef2f8 0%, #e5ebf5 100%);
  color: #b2bbc9;
  box-shadow: none;
}

.btn-next {
  background: linear-gradient(135deg, #3f8cff 0%, #246bdb 100%);
  color: #ffffff;
}

.btn-finish {
  background: linear-gradient(135deg, #56c728 0%, #33a90b 100%);
  color: #ffffff;
}

.answer-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(18, 34, 64, 0.34);
  z-index: 1000;
}

.answer-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 78vh;
  padding: 30rpx 28rpx 36rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  overflow-y: auto;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(238, 243, 252, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #6f7d95;
}

.sheet-stats {
  display: flex;
  justify-content: center;
  gap: 72rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #246bdb;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7c8ca5;
}

.sheet-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 18rpx;
}

.sheet-item {
  aspect-ratio: 1;
  border-radius: 18rpx;
  background: rgba(239, 244, 253, 0.96);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #8a95a8;
}

.sheet-item.answered {
  background: linear-gradient(135deg, #3f8cff 0%, #246bdb 100%);
  color: #ffffff;
}

.sheet-item.current {
  border-color: #246bdb;
  box-shadow: 0 10rpx 18rpx rgba(36, 107, 219, 0.14);
}

.blocks {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.block-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1f2937;
}

.block-image {
  width: 100%;
  border-radius: 18rpx;
}

.block-formula {
  font-family: 'Courier New', monospace;
  font-size: 26rpx;
  color: #1f2937;
  background: rgba(239, 244, 253, 0.96);
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
}

.block-table {
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid #dbe4f3;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #dbe4f3;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  flex: 1;
  padding: 12rpx;
  font-size: 24rpx;
  color: #334155;
  border-right: 1rpx solid #dbe4f3;
}

.table-cell:last-child {
  border-right: none;
}

.case-children {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed rgba(205, 222, 248, 0.92);
}

.case-child {
  margin-bottom: 28rpx;
}

.blank-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.blank-input,
.short-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  background: rgba(255, 255, 255, 0.98);
  font-size: 28rpx;
  color: #1f2937;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.84);
}

.short-input {
  margin-bottom: 24rpx;
}

.short-textarea {
  min-height: 180rpx;
}

<view class="container">
  <view class="hero-panel">
    <view class="page-header" style="padding-top: {{navBar.statusBarHeight}}px;">
      <view class="page-header-bar" style="height: {{navBar.navHeight}}px;">
        <view class="page-header-back" bindtap="onBack">
          <text class="page-header-back-text">{{ui.backIcon}}</text>
        </view>
        <text class="page-header-title">{{ui.title}}</text>
        <view class="page-header-placeholder"></view>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-badge">{{wrongExams.length}}{{ui.badgeSuffix}}</view>
      <view class="hero-title">{{ui.title}}</view>
      <view class="hero-subtitle">{{ui.desc}}</view>
      <view class="hero-stats">
        <view class="hero-stat">
          <text class="hero-stat-value">{{totalWrongCount}}</text>
          <text class="hero-stat-label">{{ui.heroTotalLabel}}</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-value">{{wrongExams.length}}</text>
          <text class="hero-stat-label">{{ui.heroExamLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">{{ui.listTitle}}</text>
    <text class="section-pill">{{ui.listHint}}</text>
  </view>

  <view class="wrong-list">
    <view wx:if="{{wrongExams.length === 0}}" class="empty-state">
      <view class="empty-icon">错</view>
      <text class="empty-title">{{ui.emptyTitle}}</text>
      <text class="empty-desc">{{ui.emptyDesc}}</text>
    </view>

    <view wx:for="{{wrongExams}}" wx:key="_id" class="wrong-card">
      <view class="wrong-icon">{{item.displayIcon}}</view>
      <view class="wrong-main">
        <view class="wrong-name-row">
          <text class="wrong-name">{{item.name}}</text>
          <text class="wrong-badge">{{ui.reminderTag}}</text>
        </view>
        <view class="wrong-meta">
          <text class="wrong-category">{{item.category || ui.defaultCategory}}</text>
          <text class="wrong-count">{{item.wrongCount}}{{ui.countSuffix}}</text>
        </view>
      </view>
      <button class="wrong-action" bindtap="onReviewTap" data-id="{{item._id}}" data-name="{{item.name}}">
        {{ui.action}}
      </button>
    </view>
  </view>
</view>

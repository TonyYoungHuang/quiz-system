/* pages/mine/mine.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 190rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #4B8FE9 0%, #DDEBFF 340rpx, #F3F7FD 720rpx, #F4F7FC 100%);
}

.hero-panel {
  background: linear-gradient(180deg, #4B8FE9 0%, #4A8DE8 100%);
  padding-bottom: 22rpx;
}

.page-header {
  background: transparent;
}

.page-header-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.page-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.content-shell {
  padding: 24rpx;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  box-shadow: 0 16rpx 32rpx rgba(36, 107, 219, 0.18);
}

.user-avatar {
  width: 110rpx;
  height: 110rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  border: 4rpx solid rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 66rpx;
  font-weight: 700;
  color: #111827;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  margin-bottom: 18rpx;
}

.user-summary {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.96);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 22rpx;
}

.stat-card {
  min-height: 150rpx;
  padding: 28rpx 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.stat-value {
  font-size: 54rpx;
  font-weight: 700;
  color: #246BDB;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #7C8CA5;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 28rpx 4rpx 18rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1F2937;
}

.section-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8A95A8;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.menu-icon {
  width: 78rpx;
  height: 78rpx;
  margin-right: 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.18);
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 10rpx;
}

.menu-subtitle {
  font-size: 24rpx;
  color: #8A95A8;
}

.menu-action {
  margin-left: 16rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #246BDB;
  background: rgba(240, 244, 253, 1);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
}

.version-pill {
  display: table;
  margin: 36rpx auto 0;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  box-shadow: 0 12rpx 24rpx rgba(83, 122, 196, 0.10);
  font-size: 24rpx;
  color: #8A95A8;
}


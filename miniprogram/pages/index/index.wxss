/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #4B8FE9 0%, #DDEBFF 320rpx, #F3F7FD 700rpx, #F4F7FC 100%);
}

.hero-panel {
  background: linear-gradient(180deg, #4B8FE9 0%, #4A8DE8 100%);
  padding-bottom: 24rpx;
}

.page-header {
  background: transparent;
}

.page-header-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.page-header-title {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #FFFFFF;
}

.search-bar {
  padding: 18rpx 24rpx 0;
  background: transparent;
}

.search-input {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid rgba(195, 217, 247, 0.8);
  border-radius: 42rpx;
  padding: 0 26rpx;
  box-shadow: 0 12rpx 28rpx rgba(78, 126, 199, 0.12);
}

.search-icon {
  font-size: 38rpx;
  margin-right: 14rpx;
  color: #4D86E9;
}

.search-input input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  color: #1F2937;
}

.search-placeholder {
  color: #A0A8B8;
}

.content-shell {
  margin-top: -2rpx;
  padding-top: 4rpx;
}

.entry-grid {
  padding: 14rpx 24rpx 18rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.entry-item {
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  border-radius: 22rpx;
  min-height: 128rpx;
  padding: 18rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 10rpx 24rpx rgba(83, 122, 196, 0.10);
}

.entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.22);
}

.entry-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.entry-title {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 800;
  margin-bottom: 6rpx;
}

.entry-subtitle {
  font-size: 20rpx;
  color: #8A95A8;
  font-weight: 600;
}

.category-scroll {
  background: transparent;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 24rpx 14rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 14rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(205, 222, 248, 0.9);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #246BDB;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(83, 122, 196, 0.08);
}

.category-item.active {
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  color: #fff;
  box-shadow: 0 12rpx 22rpx rgba(36, 107, 219, 0.24);
}

.exam-list {
  padding: 10rpx 24rpx 20rpx;
}

.exam-group {
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
}

.group-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1F2937;
}

.group-hint {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #9AA6BA;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(205, 222, 248, 0.88);
  font-weight: 600;
}

.exam-card {
  display: flex;
  align-items: center;
  background: linear-gradient(180deg, #FFFFFF 0%, #FDFEFF 100%);
  border: 2rpx solid rgba(205, 222, 248, 0.92);
  border-radius: 24rpx;
  padding: 22rpx 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(83, 122, 196, 0.10);
}

.exam-card.locked-card {
  opacity: 0.72;
  border-color: rgba(148, 163, 184, 0.14);
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.06);
}

.exam-card.locked-card .exam-icon {
  filter: saturate(0.7);
}

.exam-card.locked-card .exam-name,
.exam-card.locked-card .exam-category,
.exam-card.locked-card .exam-count {
  color: #94A3B8;
}

.exam-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  overflow: hidden;
  margin-right: 18rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #3F8CFF 0%, #246BDB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(36, 107, 219, 0.18);
}

.exam-icon-text {
  font-size: 46rpx;
  line-height: 1;
}

.exam-info {
  flex: 1;
  min-width: 0;
}

.exam-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.exam-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1F2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.exam-pill {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #246BDB;
  background: rgba(226, 236, 253, 1);
}

.exam-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.exam-category {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(228, 236, 254, 1);
  color: #246BDB;
  font-size: 22rpx;
  font-weight: 700;
}

.exam-count {
  font-size: 24rpx;
  color: #7C8CA5;
  font-weight: 700;
}

.exam-remaining {
  font-size: 24rpx;
  color: #D97706;
  font-weight: 700;
}

.exam-status {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-badge.activated {
  background: linear-gradient(180deg, rgba(239, 255, 244, 0.96) 0%, rgba(227, 252, 235, 0.96) 100%);
  color: #52C41A;
  border: 2rpx solid rgba(189, 235, 185, 0.92);
}

.status-badge.locked {
  background: rgba(232, 239, 252, 1);
  color: #246BDB;
  border: 2rpx solid rgba(205, 222, 248, 0.92);
}

.status-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

<!--pages/activate/activate.wxml-->
<view class="container">
  <!-- 科目信息 -->
  <view wx:if="{{examId}}" class="exam-info-card">
    <view class="exam-info-title">正在激活</view>
    <view class="exam-info-name">{{examName || '该科目'}}</view>
  </view>

  <!-- 输入激活码 -->
  <view class="activate-card">
    <view class="card-title">输入激活码</view>
    <view class="card-desc">请输入您购买后获得的激活码</view>

    <view class="code-input-wrapper">
      <input
        class="code-input"
        type="text"
        placeholder="请输入8-12位激活码"
        value="{{activationCode}}"
        bindinput="onCodeInput"
        bindconfirm="onActivate"
        maxlength="12"
        auto-focus
        confirm-type="done"
      />
      <view class="code-clear" wx:if="{{activationCode}}" bindtap="onClearCode">
        <text>✕</text>
      </view>
    </view>

    <view class="code-tips">
      <text class="tips-icon">💡</text>
      <text>激活码为8-12位大写字母或数字组合</text>
    </view>
  </view>

  <!-- 激活按钮 -->
  <button
    class="activate-btn {{activating || !activationCode ? 'disabled' : ''}}"
    bindtap="onActivate"
    disabled="{{activating || !activationCode}}"
  >
    {{activating ? '激活中...' : '立即激活'}}
  </button>

  <!-- 已激活的科目列表 -->
  <view class="activated-list">
    <view class="list-title">我的已激活科目</view>

    <view wx:if="{{activatedExams.length === 0}}" class="empty-activated">
      <text class="empty-icon">📦</text>
      <text>还没有激活任何科目</text>
    </view>

    <view wx:else class="exam-items">
      <view
        wx:for="{{activatedExams}}"
        wx:key="_id"
        class="activated-item"
        bindtap="onExamTap"
        data-exam="{{item.examId}}"
      >
        <view class="item-icon">
          <text class="item-icon-text">{{item.examId.iconText || '📚'}}</text>
        </view>
        <view class="item-info">
          <view class="item-name">{{item.examId.name}}</view>
          <view class="item-meta">
            <text class="tag tag-primary">{{item.examId.category}}</text>
          </view>
        </view>
        <view class="item-arrow">
          <text>›</text>
        </view>
      </view>
    </view>
  </view>
</view>

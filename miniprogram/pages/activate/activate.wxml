<!--pages/activate/activate.wxml-->
<view class="container">
  <view wx:if="{{examId}}" class="exam-info-card">
    <view class="exam-info-title">{{ui.pendingTitle}}</view>
    <view class="exam-info-name">{{examName || ui.noExam}}</view>
  </view>

  <view class="activate-card">
    <view class="card-title">{{ui.activateTitle}}</view>
    <view class="card-desc">{{ui.activateDesc}}</view>

    <view class="code-input-wrapper">
      <input
        class="code-input"
        type="text"
        placeholder="{{ui.codePlaceholder}}"
        value="{{activationCode}}"
        bindinput="onCodeInput"
        bindconfirm="onActivate"
        maxlength="12"
        auto-focus
        confirm-type="done"
      />
      <view class="code-clear" wx:if="{{activationCode}}" bindtap="onClearCode">
        <text>×</text>
      </view>
    </view>

    <view class="code-tips">
      <text class="tips-icon">{{ui.tipsLabel}}</text>
      <text>{{ui.tipsText}}</text>
    </view>
  </view>

  <button
    class="activate-btn {{activating || !activationCode ? 'disabled' : ''}}"
    bindtap="onActivate"
    disabled="{{activating || !activationCode}}"
  >
    {{activating ? ui.activating : ui.activateNow}}
  </button>

  <view class="activated-list">
    <view class="list-title">{{ui.activatedList}}</view>

    <view wx:if="{{activatedExams.length === 0}}" class="empty-activated">
      <text class="empty-icon">{{ui.emptyTitle}}</text>
      <text>{{ui.emptyText}}</text>
    </view>

    <view wx:else class="exam-items">
      <view
        wx:for="{{activatedExams}}"
        wx:key="_id"
        class="activated-item"
        bindtap="onExamTap"
        data-exam="{{item.examId}}"
      >
        <view class="item-icon">
          <text class="item-icon-text">{{item.examId.iconText || ui.defaultIcon}}</text>
        </view>
        <view class="item-info">
          <view class="item-name">{{item.examId.name}}</view>
          <view class="item-meta">
            <text class="tag tag-primary">{{item.examId.category}}</text>
          </view>
        </view>
        <view class="item-arrow">
          <text>></text>
        </view>
      </view>
    </view>
  </view>
</view>

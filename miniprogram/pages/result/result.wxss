.container {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.result-card,
.comment-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.result-card {
  padding: 40rpx 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.exam-title {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.score-row {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.score-value {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.score-meta {
  flex: 1;
}

.score-label {
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
}

.accuracy-line {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.stats-grid {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 24rpx;
}

.stat-item.success {
  background: rgba(34, 197, 94, 0.1);
}

.stat-item.danger {
  background: rgba(239, 68, 68, 0.1);
}

.stat-item.warning {
  background: rgba(245, 158, 11, 0.12);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.comment-card {
  margin-top: 24rpx;
  padding: 28rpx;
  text-align: center;
}

.comment-icon {
  font-size: 64rpx;
}

.comment-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #374151;
}

.action-buttons {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.action-buttons button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #357abd;
  border: 2rpx solid #357abd;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
}
